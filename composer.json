{
    "name": "institution/neo-lms-backend",
    "description": "Backend de integración NEO LMS (CYPHER Learning) con Control Escolar",
    "type": "project",
    "require": {
        "php": "^8.4",
        "bacon/bacon-qr-code": "^3.1",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.29",
        "laravel/sanctum": "^4.0",
        "league/csv": "^9.14",
        "pragmarx/google2fa": "^9.0",
        "predis/predis": "^2.2",
        "spatie/laravel-permission": "^6.25"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",

            "Shared\\": "src/Shared/",

            "Auth\\": "src/Auth/",

            "Academic\\": "src/Academic/",
            "Curricular\\": "src/Curricular/",
            "Enrollment\\": "src/Enrollment/",
            "Grades\\": "src/Grades/",

            "NeoLms\\": "src/NeoLms/",
            "ControlEscolar\\": "src/ControlEscolar/",
            "Scheduler\\": "src/Scheduler/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "php artisan test",
        "test:unit": "php artisan test --testsuite=Unit",
        "test:integration": "php artisan test --testsuite=Integration",
        "lint": "./vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
